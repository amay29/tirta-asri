generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int                @id @default(autoincrement())
  nama              String
  password          String
  noRumah           String
  role              Role               @default(WARGA)
  createdAt         DateTime           @default(now())
  surat             Surat[]
  tagihan           Tagihan[]
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]
}

model Tagihan {
  id         Int           @id @default(autoincrement())
  bulan      String
  tahun      Int
  jumlah     Int
  deadline   DateTime?
  status     StatusTagihan @default(BELUM_BAYAR)
  createdAt  DateTime      @default(now())
  userId     Int
  pembayaran Pembayaran?
  user       User          @relation(fields: [userId], references: [id])
}

model Pembayaran {
  id            Int              @id @default(autoincrement())
  jumlah        Int
  metodeBayar   String
  status        StatusPembayaran @default(PENDING)
  midtransId    String?
  buktiTransfer String?
  disetujuiOleh String?
  createdAt     DateTime         @default(now())
  tagihanId     Int              @unique
  tagihan       Tagihan          @relation(fields: [tagihanId], references: [id])
}

model Surat {
  id         Int         @id @default(autoincrement())
  jenisSurat String
  keterangan String?
  isiSurat   String?
  status     StatusSurat @default(PENDING)
  filePdf    String?
  createdAt  DateTime    @default(now())
  userId     Int
  user       User        @relation(fields: [userId], references: [id])
}

model Pengeluaran {
  id        Int      @id @default(autoincrement())
  keperluan String
  nominal   Int
  sumber    String
  createdAt DateTime @default(now())
}

model Pengumuman {
  id           Int      @id @default(autoincrement())
  judul        String
  isi          String
  foto         String?
  lampiranUrl  String?
  lampiranName String?
  lampiranType String? // 'image' | 'document'
  penting      Boolean  @default(false)
  pembuatRole  String?
  pembuatNama  String?
  createdAt    DateTime @default(now())
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  WARGA
  ADMIN_IURAN
  ADMIN_RT
}

enum StatusTagihan {
  BELUM_BAYAR
  SUDAH_BAYAR
}

enum StatusPembayaran {
  PENDING
  SUCCESS
  FAILED
}

enum StatusSurat {
  PENDING
  DIPROSES
  SELESAI
  DITOLAK
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  userId    Int?
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
